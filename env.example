# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# Production Backend URL (update when deploying)
# NEXT_PUBLIC_API_URL=https://your-backend-url.com

# Database URL (for backend)
DATABASE_URL=postgresql://username:password@localhost:5432/dse_db

# Session Secret (for backend)
SESSION_SECRET=your-session-secret-here

# Environment
NODE_ENV=production

# For Vercel deployment, add these in Vercel dashboard:
# NEXT_PUBLIC_API_URL=https://your-backend-production-url.com